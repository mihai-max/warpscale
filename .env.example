# Headscale control server URL (no trailing slash).
HEADSCALE_URL=https://headscale.example.com

# Pre-auth key from Headscale (OPTIONAL).
#   headscale preauthkeys create --user <user> --reusable --expiration 24h
# Leave blank for interactive login: the container prints an auth URL in its
# logs (`docker compose logs -f`). The login is then saved to the ts-data
# volume, so it is only needed once.
TS_AUTHKEY=

# Hostname this node registers under in Headscale.
TS_HOSTNAME=warp-exit

# Optional extra args appended to `tailscale up` (space-separated), e.g.:
#   --advertise-tags=tag:exit --accept-routes
TS_EXTRA_ARGS=

# Optional Cloudflare WARP+ license key (leave blank for the free tier).
WARP_LICENSE_KEY=
